# MeinGPT: loads MEINGPT_API_KEY from global environment
# Set your key: export MEINGPT_API_KEY="sk_meingpt_YOUR_KEY_HERE" in ~/.zshrc
OPENAI_API_KEY=${MEINGPT_API_KEY}
OPENAI_BASE_URL="https://app.meingpt.com/api/openai/v1"
PREFERRED_PROVIDER="openai"
BIG_MODEL="claude-sonnet-4-6"
SMALL_MODEL="gpt-5-2"
